{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dex.local/schemas/work-item-board.json",
  "title": "WorkItemBoard",
  "description": "Generic board payload for tasks, PRD slices, or epics. Same shape can be exported from PRD tooling later.",
  "type": "object",
  "required": ["schemaVersion", "items"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "title": { "type": "string", "description": "Board title shown in UI" },
    "updated": { "type": "string", "format": "date" },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/workItem" }
    }
  },
  "$defs": {
    "workItem": {
      "type": "object",
      "required": ["id", "kind", "title", "priorityBand", "rankScore", "status"],
      "properties": {
        "id": { "type": "string", "description": "Stable id, e.g. task-20260323-001 or PRD-Feed-AC-01" },
        "kind": {
          "type": "string",
          "enum": ["task", "prd", "epic", "spike", "doc"],
          "description": "task = backlog; prd = requirement slice; epic = large initiative"
        },
        "title": { "type": "string" },
        "summary": { "type": "string", "description": "Longer context / acceptance-style notes" },
        "nextAction": { "type": "string", "description": "Immediate next step if different from summary" },
        "priorityBand": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
        "rankScore": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "description": "Sort key within the board; higher = tackle first. P0 typically 85+, P1 70–84, P2 40–69, P3 10–39."
        },
        "status": {
          "type": "string",
          "enum": ["todo", "on_hold", "in_progress", "done"],
          "description": "Kanban: todo = not started / queued; on_hold = blocked or waiting; in_progress = active; done = complete. Legacy open→todo, started→in_progress, blocked→on_hold."
        },
        "pillar": { "type": "string", "description": "Strategic pillar id from System/pillars.yaml" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "href"],
            "properties": {
              "label": { "type": "string" },
              "href": { "type": "string", "description": "Vault-relative path or https URL" }
            }
          }
        }
      }
    }
  }
}
